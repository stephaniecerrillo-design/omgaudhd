<script>
  const ctxBar = document.getElementById('ctx-bar');
  const ctxProg = document.getElementById('ctx-prog');
  const fab = document.getElementById('fab');
  const progressEl = document.getElementById('progress');

  new IntersectionObserver(
    e => {
      const hidden = !e[0].isIntersecting;
      ctxBar.classList.toggle('visible', hidden);
      fab.classList.toggle('visible', hidden);
    },
    { rootMargin: '-52px 0px 0px 0px' }
  ).observe(document.querySelector('.art-head'));

  const footer = document.querySelector('footer');

  window.addEventListener('scroll', () => {
    const doc = document.documentElement;
    const pct = doc.scrollTop / (doc.scrollHeight - doc.clientHeight) * 100;
    progressEl.style.width = pct + '%';
    ctxProg.style.width = pct + '%';
    const fTop = footer.getBoundingClientRect().top;
    fab.style.bottom = fTop < window.innerHeight - 60
      ? (window.innerHeight - fTop + 16) + 'px'
      : '28px';
  }, { passive: true });
</script>
<script>
(function(){
  var btn = document.getElementById('burger');
  var ctxBtn = document.getElementById('ctx-burger');
  var nav = document.getElementById('navlinks');
  if(!nav) return;
  function openMenu(open){
    nav.classList.toggle('open',open);
    if(btn) btn.classList.toggle('open',open);
    if(ctxBtn) ctxBtn.classList.toggle('open',open);
  }
  function toggle(){ openMenu(!nav.classList.contains('open')); }
  if(btn) btn.addEventListener('click',toggle);
  if(ctxBtn) ctxBtn.addEventListener('click',toggle);
  nav.querySelectorAll('a').forEach(function(a){
    a.addEventListener('click',function(){ openMenu(false); });
  });
  nav.querySelectorAll('.nav-section-btn').forEach(function(secBtn){
    secBtn.addEventListener('click',function(){
      var target=document.getElementById(this.dataset.target);
      if(!target) return;
      var isOpen=!target.classList.contains('open');
      nav.querySelectorAll('.nav-section-items').forEach(function(el){el.classList.remove('open');});
      nav.querySelectorAll('.nav-section-btn').forEach(function(el){el.classList.remove('open');});
      if(isOpen){target.classList.add('open');secBtn.classList.add('open');}
    });
  });
})();
</script>
